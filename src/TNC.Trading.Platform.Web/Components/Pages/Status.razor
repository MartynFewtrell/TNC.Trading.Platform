@page "/status"
@attribute [Authorize(Policy = PlatformAuthenticationDefaults.Policies.Viewer)]
@inject PlatformApiClient PlatformApiClient
@inject PlatformNavigationAccessCoordinator NavigationAccessCoordinator
@inject PlatformOperatorContextAccessor OperatorContextAccessor

<PageTitle>Platform status</PageTitle>

@if (!hasRequiredScope)
{
    <section class="panel platform-callout">
        <h1>Platform status</h1>
        <p>Redirecting...</p>
    </section>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="panel platform-callout">
        <h1>Platform status</h1>
        <p class="error">@loadError</p>
    </section>
}
else if (status is null || events is null)
{
    <section class="panel platform-callout">
        <h1>Platform status</h1>
        <p>Loading platform status...</p>
    </section>
}
else
{
    <section class="panel platform-page-header">
        <div>
            <h1>Platform status</h1>
            <p class="hint">Review the current environment, supervision, and recent authentication activity.</p>
        </div>
    </section>

    <PlatformAccordionSection Title="Environment" IsOpen="true">
        <section class="panel" data-testid="status-environment-panel">
            <dl class="platform-key-value-grid">
                <dt>Platform environment</dt>
                <dd data-testid="platform-environment-value">@status.PlatformEnvironment</dd>
                <dt>Broker environment</dt>
                <dd data-testid="broker-environment-value">@status.BrokerEnvironment</dd>
                <dt>Live option availability</dt>
                <dd data-testid="live-option-availability-value">@(status.LiveOptionAvailable ? "Available" : "Visible but blocked")</dd>
                <dt>Last update</dt>
                <dd>@status.UpdatedAtUtc.ToLocalTime().ToString("g")</dd>
            </dl>
        </section>
    </PlatformAccordionSection>

    <PlatformAccordionSection Title="Trading schedule" IsOpen="false">
        <section class="panel" data-testid="status-trading-schedule-panel">
            <dl class="platform-key-value-grid">
                <dt>Schedule state</dt>
                <dd data-testid="trading-schedule-state-value">@(status.TradingScheduleState.IsActive ? "Active" : "Inactive")</dd>
                <dt>Reason</dt>
                <dd data-testid="trading-schedule-reason-value">@status.TradingScheduleState.Reason</dd>
                <dt>Daily window</dt>
                <dd>@status.TradingSchedule.StartOfDay - @status.TradingSchedule.EndOfDay (@status.TradingSchedule.TimeZone)</dd>
                <dt>Trading days</dt>
                <dd>@string.Join(", ", status.TradingSchedule.TradingDays)</dd>
                <dt>Weekend behavior</dt>
                <dd>@status.TradingSchedule.WeekendBehavior</dd>
                <dt>Bank holidays</dt>
                <dd>@(status.TradingSchedule.BankHolidayExclusions.Count == 0 ? "None configured" : string.Join(", ", status.TradingSchedule.BankHolidayExclusions))</dd>
            </dl>
        </section>
    </PlatformAccordionSection>

    <PlatformAccordionSection Title="Authentication supervision" IsOpen="false">
        <section class="panel" data-testid="status-auth-panel">
            <dl class="platform-key-value-grid">
                <dt>Session status</dt>
                <dd data-testid="auth-session-status-value">@status.AuthState.SessionStatus</dd>
                <dt>Degraded</dt>
                <dd data-testid="auth-degraded-value">@(status.AuthState.IsDegraded ? "Yes" : "No")</dd>
                <dt>Blocked reason</dt>
                <dd data-testid="auth-blocked-reason-value">@(status.AuthState.BlockedReason ?? "None")</dd>
                <dt>Retry phase</dt>
                <dd data-testid="auth-retry-phase-value">@status.RetryState.Phase</dd>
                <dt>Automatic attempt number</dt>
                <dd data-testid="auth-automatic-attempt-value">@status.RetryState.AutomaticAttemptNumber</dd>
                <dt>Next retry</dt>
                <dd data-testid="auth-next-retry-value">@(status.RetryState.NextRetryAtUtc?.ToString("u") ?? "Not scheduled")</dd>
            </dl>

            @if (status.AuthState.IsDegraded)
            {
                <p class="warning" role="alert" data-testid="auth-degraded-warning">Auth-dependent actions are blocked until the platform can restore an IG demo session.</p>
            }

            @if (operatorContext?.IsOperator == true)
            {
                <button class="platform-primary-action platform-manual-retry-button" data-testid="manual-retry-button" @onclick="TriggerManualRetryAsync" disabled="@(!status.RetryState.ManualRetryAvailable || manualRetryInProgress)">
                    @(manualRetryInProgress ? "Retrying..." : "Trigger manual retry")
                </button>
            }

            @if (!string.IsNullOrWhiteSpace(manualRetryMessage))
            {
                <p role="status" data-testid="manual-retry-message">@manualRetryMessage</p>
            }
        </section>
    </PlatformAccordionSection>

    <PlatformAccordionSection Title="Recent auth events" IsOpen="false">
        <section class="panel">
            @if (events.Events.Count == 0)
            {
                <p>No auth events recorded.</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Type</th>
                            <th>Summary</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var platformEvent in events.Events.Take(10))
                    {
                        <tr>
                            <td>@platformEvent.OccurredAtUtc.ToString("u")</td>
                            <td>@platformEvent.EventType</td>
                            <td>@platformEvent.Summary</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </section>
    </PlatformAccordionSection>
}

@code {
    private PlatformStatusViewModel? status;
    private PlatformEventsViewModel? events;
    private PlatformOperatorContext? operatorContext;
    private bool hasRequiredScope;
    private bool manualRetryInProgress;
    private string? loadError;
    private string? manualRetryMessage;

    protected override async Task OnInitializedAsync()
    {
        operatorContext = await OperatorContextAccessor.GetCurrentAsync();
        hasRequiredScope = await NavigationAccessCoordinator.EnsureRequiredScopesAsync(
            "/status",
            PlatformAuthenticationDefaults.Scopes.Viewer);
        if (!hasRequiredScope)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loadError = null;

        try
        {
            status = await PlatformApiClient.GetStatusAsync(CancellationToken.None);
            events = await PlatformApiClient.GetAuthEventsAsync(status.BrokerEnvironment, CancellationToken.None);
        }
        catch (Exception exception) when (exception is HttpRequestException or PlatformScopeChallengeRequiredException or InvalidOperationException)
        {
            loadError = $"Unable to load platform status: {exception.Message}";
        }
    }

    private async Task TriggerManualRetryAsync()
    {
        manualRetryInProgress = true;
        manualRetryMessage = null;

        try
        {
            var retry = await PlatformApiClient.TriggerManualRetryAsync(CancellationToken.None);
            manualRetryMessage = $"Manual retry started with cycle id {retry.RetryCycleId}.";
        }
        catch (HttpRequestException exception)
        {
            manualRetryMessage = $"Manual retry could not be started: {exception.Message}";
        }
        finally
        {
            manualRetryInProgress = false;
            await LoadAsync();
        }
    }
}
