@inherits LayoutComponentBase
@implements IDisposable
@inject PlatformShellContextProvider ShellContextProvider

<div class="platform-app-shell @(isSidebarCollapsed ? "platform-app-shell--collapsed" : string.Empty)">
    <PlatformHeader Environment="shellEnvironment"
                    IsSidebarCollapsed="isSidebarCollapsed"
                    OperatorContext="operatorContext"
                    ShowSidebarToggle="@(operatorContext?.HasAnyPlatformRole == true)"
                    ShowThemeToggle="@(operatorContext?.HasAnyPlatformRole == true)"
                    ToggleSidebar="ToggleSidebarAsync" />

    <div class="platform-app-shell__body @(operatorContext?.HasAnyPlatformRole == true ? string.Empty : "platform-app-shell__body--full-width")">
        @if (operatorContext?.HasAnyPlatformRole == true)
        {
            <nav class="platform-sidebar" aria-label="Primary">
                <div class="platform-sidebar__brand">Operator workspace</div>

                <PlatformNavItem Href="/" Match="NavLinkMatch.All" Icon="home" Text="Home" />

                @if (operatorContext.IsViewer)
                {
                    <PlatformNavItem Href="/status" Icon="monitor_heart" Text="Status" />
                }

                @if (operatorContext.IsOperator)
                {
                    <PlatformNavItem Href="/configuration" Icon="settings" Text="Configuration" />
                }

                @if (operatorContext.IsAdministrator)
                {
                    <PlatformNavItem Href="/administration/authentication" Icon="admin_panel_settings" Text="Authentication administration" />
                }
            </nav>
        }

        <main class="platform-content">
            <section class="platform-page-frame">
                @Body
            </section>
        </main>
    </div>
</div>

@code {
    private PlatformOperatorContext? operatorContext;
    private PlatformShellEnvironment? shellEnvironment;
    private bool isSidebarCollapsed;

    protected override async Task OnInitializedAsync()
    {
        operatorContext = await ShellContextProvider.GetOperatorContextAsync();
        shellEnvironment = await ShellContextProvider.GetEnvironmentAsync();
    }

    public void Dispose()
    {
    }

    private Task ToggleSidebarAsync()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
        return Task.CompletedTask;
    }
}
