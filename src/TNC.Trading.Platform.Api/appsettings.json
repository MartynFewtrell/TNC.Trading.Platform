{
  "Authentication": {
    "Provider": "Keycloak",
    "ApiAudience": "tnc-trading-platform-api",
    "RequiredScopes": [
      "platform.viewer"
    ],
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/tnc-trading-platform",
      "Realm": "tnc-trading-platform",
      "ApiClientId": "tnc-trading-platform-api"
    },
    "Entra": {
      "Instance": "https://login.microsoftonline.com/"
    },
    "Test": {
      "Issuer": "https://test-auth.local",
      "Audience": "tnc-trading-platform-api",
      "SigningKey": "0123456789abcdef0123456789abcdef"
    },
    "Authorization": {
      "RoleClaimType": "role",
      "DisplayNameClaimType": "name",
      "DisplayNameFallbackClaimType": "preferred_username"
    }
  },
  "Health": {
    "Path": {
      "Liveness": "/health/live",
      "Readiness": "/health/ready"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Bootstrap": {
    "PlatformEnvironment": "Test",
    "BrokerEnvironment": "Demo",
    "TradingSchedule": {
      "StartOfDay": "08:00",
      "EndOfDay": "16:30",
      "TradingDays": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "WeekendBehavior": "ExcludeWeekends",
      "TimeZone": "UTC"
    },
    "AuthSimulation": {
      "SessionLifetimeSeconds": 900
    },
    "RetryPolicy": {
      "InitialDelaySeconds": 1,
      "MaxAutomaticRetries": 5,
      "Multiplier": 2,
      "MaxDelaySeconds": 60,
      "PeriodicDelayMinutes": 5
    },
    "NotificationSettings": {
      "EmailTo": "operator@local.test"
    },
    "UpdatedBy": "api-bootstrap"
  },
  "AllowedHosts": "*"
}
